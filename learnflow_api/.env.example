# ── Database ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=learnflow

# Flask
FLASK_ENV=development
SECRET_KEY= 

# ── Firebase ───────────────────────────────────────────────────────────────
FIREBASE_CREDENTIALS=config/serviceAccountKey.json

# ── Flask ──────────────────────────────────────────────────────────────────
# FIX: เปลี่ยนเป็น false ก่อน deploy production
FLASK_DEBUG=true
FLASK_PORT=5000

# ── CORS ───────────────────────────────────────────────────────────────────
# FIX: ระบุ origin จริงตอน production เช่น https://learnflow.example.com
# ระหว่าง dev ใช้ * ได้
CORS_ORIGINS=*
