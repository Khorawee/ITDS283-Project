# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=learnflow

# Firebase Admin SDK
FIREBASE_CREDENTIALS=config/serviceAccountKey.json

# Flask
FLASK_ENV=development
SECRET_KEY=your_secret_key
