# ── Database (Local Dev) ───────────────────────────────────────────────────
# Railway จะ inject MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE อัตโนมัติ
# ตัวแปรด้านล่างใช้สำหรับ local dev เท่านั้น
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=learnflow

# ── Firebase ───────────────────────────────────────────────────────────────
# Local dev: ชี้ไปที่ไฟล์ serviceAccountKey.json
FIREBASE_CREDENTIALS=config/serviceAccountKey.json

# Railway/Production: วาง content ทั้งหมดของ serviceAccountKey.json ที่นี่ (JSON string)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ── Flask ──────────────────────────────────────────────────────────────────
FLASK_DEBUG=false
FLASK_PORT=5000
SECRET_KEY=your_secret_key_here

# ── CORS ───────────────────────────────────────────────────────────────────
# Production: ระบุ origin จริง เช่น https://learnflow.example.com
# Dev: ใช้ * ได้
CORS_ORIGINS=*
